@page
@model ITGSA.Frontend.Pages.IndexModel
@{
    ViewData["Title"] = "ITGSA - Sistema de Facturación";
}

<div class="container mt-4">
    <h1 class="text-center mb-4">🏪 ITGSA - Sistema de Gestión</h1>
    <div class="row g-3">
        <div class="col-md-3">
            <a href="/Config" class="btn btn-primary btn-lg w-100">
                📋 Cargar Configuración
            </a>
        </div>
        <div class="col-md-3">
            <a href="/Transacciones" class="btn btn-success btn-lg w-100">
                💳 Cargar Transacciones
            </a>
        </div>
        <div class="col-md-3">
            <a href="/Peticiones" class="btn btn-info btn-lg w-100 text-white">
                🔍 Peticiones
            </a>
        </div>
        <div class="col-md-3">
            <form method="post" action="/Reset">
                <button type="submit" class="btn btn-danger btn-lg w-100"
                        onclick="return confirm('¿Resetear todos los datos?')">
                    🗑️ Resetear Datos
                </button>
            </form>
        </div>
    </div>
</div>